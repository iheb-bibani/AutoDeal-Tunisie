# Ne JAMAIS committer : identifiants réels
.env

# Fichiers Python courants
__pycache__/
*.pyc
.venv/
venv/

# Dossier de session Playwright/Patchright (cookies persistés pour automobile.tn)
user_data/

# Journaux d'execution : regenerés à chaque run, ils créent des modifications
# à chaque commit automatique et polluent l'historique.
logs/
*.log
